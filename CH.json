{
  "log": {
    "loglevel": "warning"
  },
  "dns": {
    "queryStrategy": "UseIPv4",
    "servers": [
      {
        "address": "223.5.5.5",
        "domains": [
          "geosite:ru",
          "geosite:category-ru"
        ],
        "skipFallback": true
      },
      {
        "address": "https://1.1.1.1/dns-query",
        "domains": [
          "geosite:geolocation-!cn"
        ]
      },
      "https://8.8.8.8/dns-query"
    ],
    "disableFallbackIfMatch": true
  },
  "inbounds": [
    {
      "tag": "socks-in",
      "listen": "127.0.0.1",
      "port": 10808,
      "protocol": "socks",
      "settings": {
        "auth": "noauth",
        "udp": true
      },
      "sniffing": {
        "enabled": true,
        "destOverride": [
          "tls",
          "http",
          "quic",
          "fakedns"
        ],
        "metadataOnly": false
      }
    },
    {
      "tag": "http-in",
      "listen": "127.0.0.1",
      "port": 10809,
      "protocol": "http",
      "settings": {
        "auth": "noauth",
        "udp": true
      },
      "sniffing": {
        "enabled": true,
        "destOverride": [
          "tls",
          "http",
          "quic",
          "fakedns"
        ],
        "metadataOnly": false
      }
    }
  ],
  "outbounds": [
    {
      "tag": "vless-1",
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "103.100.158.109",
            "port": 443,
            "users": [
              {
                "id": "64c1b992-47ff-42ef-8d6d-d7ee13c5b716",
                "encryption": "none",
                "level": 0,
                "flow": "xtls-rprx-vision"
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "serverName": "www.apple.com",
          "fingerprint": "safari",
          "publicKey": "t0i2PDg8pHUCNi_GHbe7PHAUvI3wKIvH3d3c_g26kCE",
          "shortId": "4a670fd6fdbb91ad",
          "spiderX": "/",
          "show": false
        },
        "sockopt": {
          "mark": 255,
          "tcpFastOpen": true,
          "tcpKeepAliveIdle": 100,
          "tcpNoDelay": true,
          "fragment": {
            "packets": "tlshello",
            "length": "100-200",
            "interval": "10-20"
          },
          "noises": [
            {
              "type": "rand",
              "packet": "10-20",
              "delay": "5-10"
            }
          ]
        }
      }
    },
    {
      "tag": "direct",
      "protocol": "freedom",
      "settings": {
        "domainStrategy": "UseIPv4"
      }
    },
    {
      "tag": "block",
      "protocol": "blackhole"
    }
  ],
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "balancers": [
      {
        "tag": "vless-balancer",
        "selector": [
          "vless-"
        ],
        "strategy": {
          "type": "leastPing"
        }
      }
    ],
    "rules": [
      {
        "type": "field",
        "ip": [
          "geoip:private"
        ],
        "outboundTag": "direct"
      },
      {
        "type": "field",
        "domain": [
          "geosite:ru",
          "geosite:category-ru"
        ],
        "outboundTag": "direct"
      },
      {
        "type": "field",
        "ip": [
          "geoip:ru"
        ],
        "outboundTag": "direct"
      },
      {
        "type": "field",
        "network": "tcp,udp",
        "balancerTag": "vless-balancer"
      }
    ]
  },
  "burstObservatory": {
    "subjectSelector": [
      "vless-"
    ],
    "pingConfig": {
      "destination": "https://t.me/",
      "interval": "30s",
      "timeout": "15s",
      "burstSize": 10,
      "burstInterval": "1000ms"
